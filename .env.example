# ============================================================
#  S&A NexTech AI — Environment Variables
#  Copy this file to .env.local and fill in the values
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Get these from: https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── HuggingFace ─────────────────────────────────────────────
# Free token from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_your_token_here

# ── AI Model ────────────────────────────────────────────────
# Recommended free models:
#   mistralai/Mistral-7B-Instruct-v0.3   (best quality)
#   HuggingFaceH4/zephyr-7b-beta         (fast, reliable)
#   microsoft/Phi-3-mini-4k-instruct     (very fast)
AI_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_RPM=20          # requests per minute per IP
RATE_LIMIT_RPD=200         # requests per day per IP

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=S&A NexTech AI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin ───────────────────────────────────────────────────
# Simple password to protect the admin panel
ADMIN_SECRET=change-this-to-a-strong-password
